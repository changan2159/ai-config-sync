{
  "mcpServers": {
    "fetch": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/shared/fetch.sh"
    },
    "serena": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/shared/serena-manager.sh"
    },
    "node_repl": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/shared/node-repl-linux.sh",
      "toolTimeoutSec": 120
    },
    "codegraph": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/shared/codegraph.sh",
      "args": ["serve", "--mcp"],
      "toolTimeoutSec": 120
    }
  },
  "skillRoots": [
    {
      "path": "${REPO_ROOT}/skills/shared"
    }
  ],
  "globalPromptPath": "${REPO_ROOT}/prompts/shared-global-prompt.md",
  "include": ["*"],
  "targets": {
    "codex": {
      "configPath": "${HOME}/.codex/config.toml",
      "skillsDir": "${HOME}/.codex/skills-shared",
      "skillRoots": [
        {
          "path": "${REPO_ROOT}/skills/codex"
        }
      ],
      "globalPromptPath": "${HOME}/.codex/AGENTS.md",
      "globalPromptAppendPath": "${REPO_ROOT}/prompts/codex-global-prompt.md"
    },
    "claude": {
      "configPath": "${HOME}/.claude.json",
      "skillsDir": "${HOME}/.claude/skills",
      "globalPromptPath": "${HOME}/.claude/CLAUDE.md",
      "globalPromptAppendPath": "${REPO_ROOT}/prompts/claude-global-prompt.md"
    },
    "opencode": {
      "configPath": "${HOME}/.config/opencode/opencode.jsonc",
      "agentPrefix": "skill-",
      "globalPromptPath": "${HOME}/.config/opencode/AGENTS.md",
      "globalPromptAppendPath": "${REPO_ROOT}/prompts/opencode-global-prompt.md"
    },
    "pi": {
      "settingsPath": "${HOME}/.pi/agent/settings.json",
      "mcpConfigPath": "${HOME}/.config/mcp/mcp.json",
      "modelsPath": "${HOME}/.pi/agent/models.json",
      "skillsDir": "${HOME}/.pi/agent/skills-shared",
      "packages": [
        "npm:pi-mcp-adapter",
        "npm:@narumitw/pi-plan-mode",
        "npm:pi-subagents",
        "npm:pi-nano-context"
      ],
      "enableSkillCommands": true,
      "defaultProvider": "openai",
      "defaultModel": "gpt-5.4",
      "providers": {
        "openai": {
          "baseUrl": "http://38.145.220.6:9000/v1"
        }
      },
      "globalPromptPath": "${HOME}/.pi/agent/AGENTS.md",
      "globalPromptAppendPath": "${REPO_ROOT}/prompts/pi-global-prompt.md"
    }
  }
}
