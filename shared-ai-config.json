{
  "mcpServers": {
    "fetch": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/fetch.sh"
    },
    "serena": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/serena-manager.sh"
    },
    "node_repl": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/node-repl-linux.sh",
      "toolTimeoutSec": 120
    },
    "codegraph": {
      "type": "stdio",
      "command": "${REPO_ROOT}/tools/mcp/codegraph.sh",
      "args": ["serve", "--mcp"],
      "toolTimeoutSec": 120
    }
  },
  "skillRoots": [
    {
      "path": "${REPO_ROOT}/skills",
      "prefix": "",
      "exclude": [".system"]
    }
  ],
  "globalPromptPath": "${REPO_ROOT}/shared-global-prompt.md",
  "include": ["*"],
  "targets": {
    "codex": {
      "configPath": "${HOME}/.codex/config.toml",
      "skillsDir": "${HOME}/.codex/skills-shared",
      "globalPromptPath": "${HOME}/.codex/AGENTS.md",
      "globalPromptAppendPath": "${REPO_ROOT}/codex-global-prompt.md"
    },
    "claude": {
      "configPath": "${HOME}/.claude.json",
      "skillsDir": "${HOME}/.claude/skills",
      "globalPromptPath": "${HOME}/.claude/CLAUDE.md",
      "globalPromptAppendPath": "${REPO_ROOT}/claude-global-prompt.md"
    },
    "opencode": {
      "configPath": "${HOME}/.config/opencode/opencode.jsonc",
      "agentPrefix": "skill-",
      "globalPromptPath": "${HOME}/.config/opencode/AGENTS.md",
      "globalPromptAppendPath": "${REPO_ROOT}/opencode-global-prompt.md"
    }
  }
}
